			<!-- ============ FOOTER ============ -->
			<footer style="padding:44px clamp(20px,5vw,64px);background:#080f16;border-top:1px solid rgba(255,255,255,.06);">
				<div
					style="max-width:1180px;margin:0 auto;display:flex;flex-wrap:wrap;gap:24px;align-items:center;justify-content:space-between;"
				>
					<div style="display:flex;align-items:center;gap:12px;">
						<svg width="30" height="30" viewBox="0 0 64 64" fill="none"
							><path d="M12 29 A26 26 0 0 1 52 29" fill="none" stroke="#35c2d1" stroke-width="4.2" stroke-linecap="round"></path><path
								d="M32 23 L20 35 M32 23 L32 35 M32 23 L44 35"
								stroke="#2a7f8c"
								stroke-width="2"
								stroke-linecap="round"></path><circle cx="32" cy="19.5" r="4.4" fill="#57d6e3"></circle><rect
								x="16"
