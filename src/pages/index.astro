		<script is:inline>
			(function () {
				var reduce =
					window.matchMedia &&
					window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				var root = document.getElementById('ordo-root');
				if (!root) return;

				function initReveal() {
					var els = [].slice.call(root.querySelectorAll('[data-reveal]'));
					els.forEach(function (el) {
						el.style.opacity = '0';
						el.style.transform = 'translateY(30px)';
						el.style.transition =
							'opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1)';
						el.__revealed = false;
					});
					var onScroll = null;
					function check() {
						var vh = window.innerHeight || 800;
						var pending = 0;
						for (var i = 0; i < els.length; i++) {
							var el = els[i];
							if (el.__revealed) continue;
							var rect = el.getBoundingClientRect();
							if (rect.top < vh * 0.92) {
								el.__revealed = true;
								el.style.opacity = '1';
								el.style.transform = 'none';
							} else {
								pending++;
							}
						}
						if (!pending && onScroll) {
							window.removeEventListener('scroll', onScroll);
							onScroll = null;
						}
					}
					onScroll = check;
					window.addEventListener('scroll', check, { passive: true });
					check();
					setTimeout(check, 250);
				}

				function initParallax() {
					if (reduce) return;
					var layers = [].slice.call(root.querySelectorAll('[data-parallax]'));
					if (!layers.length) return;
					for (var i = 0; i < layers.length; i++) {
						var t = layers[i].style.transform || '';
						if (t) layers[i].setAttribute('data-base', t);
					}
					function onScroll() {
						var y = window.scrollY || window.pageYOffset || 0;
						for (var j = 0; j < layers.length; j++) {
							var l = layers[j];
							var s = parseFloat(l.getAttribute('data-parallax')) || 0;
							var base = l.getAttribute('data-base') || '';
							l.style.transform =
								base + ' translate3d(0,' + (y * s).toFixed(1) + 'px,0)';
						}
					}
					window.addEventListener('scroll', onScroll, { passive: true });
					onScroll();
				}

				function initParticles() {
					if (reduce) return;
					var c = root.querySelector('#ordo-particles');
					if (!c) return;
					var ctx = c.getContext('2d');
					var host = c.parentElement;
					var W = 0,
						H = 0,
						dpr = 1;
					function resize() {
						dpr = Math.min(2, window.devicePixelRatio || 1);
						W = host.clientWidth;
						H = host.clientHeight;
						c.width = W * dpr;
						c.height = H * dpr;
						ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
					}
					resize();
					window.addEventListener('resize', resize);
					var N = Math.min(96, Math.round(W / 20));
					var LINK = 168;
					var pts = [];
					for (var i = 0; i < N; i++) {
						pts.push({
							x: Math.random() * W,
							y: Math.random() * H,
							vx: (Math.random() - 0.5) * 0.22,
							vy: (Math.random() - 0.5) * 0.22,
							r: Math.random() * 1.5 + 0.6,
						});
					}
					function step() {
						ctx.clearRect(0, 0, W, H);
						for (var i = 0; i < pts.length; i++) {
							var p = pts[i];
							p.x += p.vx;
							p.y += p.vy;
							if (p.x < 0 || p.x > W) p.vx *= -1;
							if (p.y < 0 || p.y > H) p.vy *= -1;
						}
						for (var i = 0; i < pts.length; i++) {
							for (var j = i + 1; j < pts.length; j++) {
								var a = pts[i],
									b = pts[j];
								var dx = a.x - b.x,
									dy = a.y - b.y;
								var d = Math.hypot(dx, dy);
								if (d < LINK) {
									var al = (1 - d / LINK) * 0.3;
									ctx.strokeStyle = 'rgba(53,194,209,' + al.toFixed(3) + ')';
									ctx.lineWidth = 1;
									ctx.beginPath();
									ctx.moveTo(a.x, a.y);
									ctx.lineTo(b.x, b.y);
									ctx.stroke();
								}
							}
						}
						for (var i = 0; i < pts.length; i++) {
							var p = pts[i];
							ctx.fillStyle = 'rgba(87,214,227,0.6)';
							ctx.beginPath();
							ctx.arc(p.x, p.y, p.r, 0, 6.29);
							ctx.fill();
						}
						requestAnimationFrame(step);
					}
					step();
				}

				setTimeout(function () {
					initReveal();
					initParallax();
					initParticles();
				}, 30);
			})();
		</script>
	</body>
</html>
