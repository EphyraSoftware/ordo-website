---
const docsUrl = 'https://docs.getordo.dev';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Ordo — order for the machines you run</title>
		<meta
			name="description"
			content="Ordo is a self-hosted, declarative infrastructure management tool for teams running real workloads on their own bare metal and VMs. Define state, detect drift, apply on your terms."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;600;700;800&family=Spectral:ital,wght@0,400;0,500;1,400;1,500&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="icon"
			href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='14' fill='%230e2a35'/><path d='M11 30 A27 27 0 0 1 53 30' fill='none' stroke='%2357d6e3' stroke-width='5' stroke-linecap='round'/><circle cx='32' cy='19' r='5' fill='%238cf0fb'/><rect x='14' y='36' width='9.5' height='16' rx='3' fill='%2335c2d1'/><rect x='27.25' y='36' width='9.5' height='16' rx='3' fill='%238cf0fb'/><rect x='40.5' y='36' width='9.5' height='16' rx='3' fill='%2335c2d1'/></svg>"
		/>
		<style is:global>
			html,
			body {
				margin: 0;
				padding: 0;
				background: #0a1219;
			}
			* {
				box-sizing: border-box;
			}
			::selection {
				background: rgba(87, 214, 227, 0.28);
				color: #eef4f6;
			}
			a {
				color: #57d6e3;
				text-decoration: none;
			}
			a:hover {
				color: #8ce7f1;
			}
			#ordo-root ::-webkit-scrollbar {
				width: 10px;
				height: 10px;
			}
			#ordo-root ::-webkit-scrollbar-thumb {
				background: #1c3140;
				border-radius: 6px;
			}
			@keyframes ordoDash {
				to {
					stroke-dashoffset: -40;
				}
			}
			@keyframes ordoSweep {
				0% {
					stroke-dashoffset: 760;
				}
				55%,
				100% {
					stroke-dashoffset: 0;
				}
			}
			@keyframes ordoFloat {
				0%,
				100% {
					transform: translateY(0);
				}
				50% {
					transform: translateY(-10px);
				}
			}
			@keyframes ordoPulse {
				0%,
				100% {
					opacity: 0.35;
				}
				50% {
					opacity: 1;
				}
			}
			@keyframes ordoSpin {
				to {
					transform: rotate(360deg);
				}
			}
			@keyframes ordoRipple {
				0% {
					transform: scale(0.6);
					opacity: 0.6;
				}
				100% {
					transform: scale(1.8);
					opacity: 0;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				* {
					animation: none !important;
				}
			}
		</style>
	</head>
	<body>
		<div
			id="ordo-root"
			style="background:#0a1219;color:#eef4f6;font-family:'Schibsted Grotesk',system-ui,sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden;position:relative;"
		>
			<!-- ============ TOP STRIP ============ -->
			<div
				style="position:absolute;top:0;left:0;right:0;z-index:40;display:flex;align-items:center;justify-content:space-between;padding:26px clamp(20px,5vw,64px);"
			>
				<div style="display:flex;align-items:center;gap:15px;">
					<svg width="44" height="44" viewBox="0 0 64 64" fill="none" style="display:block;">
						<path
							d="M12 29 A26 26 0 0 1 52 29"
							fill="none"
							stroke="#35c2d1"
							stroke-width="4.2"
							stroke-linecap="round"></path>
						<path
							d="M32 23 L20 35 M32 23 L32 35 M32 23 L44 35"
							stroke="#2a7f8c"
							stroke-width="2"
							stroke-linecap="round"></path>
						<circle cx="32" cy="19.5" r="4.4" fill="#57d6e3"></circle>
						<rect x="16" y="35" width="8" height="15" rx="2.5" fill="#385061" stroke="#5f7d93" stroke-width="1.4"></rect>
						<rect x="28" y="35" width="8" height="15" rx="2.5" fill="#1c3a44" stroke="#57d6e3" stroke-width="1.7"></rect>
						<rect x="40" y="35" width="8" height="15" rx="2.5" fill="#385061" stroke="#5f7d93" stroke-width="1.4"></rect>
					</svg>
					<span style="font-weight:700;font-size:25px;letter-spacing:.16em;">ORDO</span>
				</div>
			</div>

			<!-- ============ HERO ============ -->
			<section
				style="position:relative;min-height:100vh;display:flex;align-items:center;padding:150px clamp(20px,5vw,64px) 110px;overflow:hidden;background:radial-gradient(120% 90% at 78% 8%,#0f2632 0%,#0a1219 58%);"
			>
				<canvas
					id="ordo-particles"
					style="position:absolute;inset:0;width:100%;height:100%;opacity:.9;pointer-events:none;"></canvas>
				<div
					data-parallax="0.14"
					style="position:absolute;right:clamp(8px,2vw,40px);top:9%;width:min(46vw,620px);opacity:.5;pointer-events:none;"
				>
					<svg viewBox="0 0 600 540" fill="none" style="width:100%;height:auto;overflow:visible;">
						<g stroke="#20313d" stroke-width="1"><path d="M70 300h460"></path></g>
						<path d="M150 300 A150 150 0 0 1 450 300" fill="none" stroke="#173f49" stroke-width="2"></path>
						<path
							d="M74 300 A226 226 0 0 1 526 300"
							fill="none"
							stroke="#1f8593"
							stroke-width="3"
							stroke-linecap="round"
							stroke-dasharray="760"
							style="animation:ordoSweep 7s ease-out infinite;"></path>
						<g
							stroke="#2a7f8c"
							stroke-width="2"
							stroke-linecap="round"
							stroke-dasharray="4 6"
							style="animation:ordoDash 1.6s linear infinite;"
						>
							<path d="M300 96 L117 300"></path>
							<path d="M300 96 L187 300"></path>
							<path d="M300 96 L257 300"></path>
							<path d="M300 96 L327 300"></path>
							<path d="M300 96 L397 300"></path>
							<path d="M300 96 L467 300"></path>
						</g>
						<circle cx="300" cy="74" r="16" fill="none" stroke="#35c2d1" stroke-width="3"></circle>
						<circle cx="300" cy="74" r="6" fill="#57d6e3"></circle>
						<rect x="96" y="300" width="42" height="150" rx="6" fill="#122531" stroke="#25404f" stroke-width="1.5"></rect>
						<rect x="166" y="300" width="42" height="150" rx="6" fill="#122531" stroke="#25404f" stroke-width="1.5"></rect>
						<rect x="236" y="300" width="42" height="150" rx="6" fill="#122531" stroke="#25404f" stroke-width="1.5"></rect>
						<rect x="306" y="300" width="42" height="150" rx="6" fill="#14313c" stroke="#35c2d1" stroke-width="2"></rect>
						<rect x="376" y="300" width="42" height="150" rx="6" fill="#122531" stroke="#25404f" stroke-width="1.5"></rect>
						<rect x="446" y="300" width="42" height="150" rx="6" fill="#122531" stroke="#25404f" stroke-width="1.5"></rect>
					</svg>
				</div>
				<div
					data-parallax="-0.05"
					style="position:absolute;left:-140px;bottom:-120px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(53,194,209,.10),transparent 66%);pointer-events:none;"></div>

				<div style="position:relative;z-index:5;max-width:1180px;margin:0 auto;width:100%;">
					<div data-reveal style="max-width:820px;">
						<div
							style="display:inline-flex;align-items:center;gap:12px;margin-bottom:26px;padding:7px 15px 7px 13px;border:1px solid rgba(53,194,209,.24);border-radius:100px;background:rgba(53,194,209,.06);"
						>
							<span style="width:7px;height:7px;border-radius:50%;background:#3fca97;box-shadow:0 0 10px #3fca97;"></span>
							<span
								style="font-family:'Spectral',serif;font-style:italic;font-size:15px;color:#a9c5cf;letter-spacing:.01em;"
								>ordo · order · rank · arrangement</span
							>
						</div>
						<h1
							style="margin:0;font-weight:800;font-size:clamp(46px,7.4vw,94px);line-height:.98;letter-spacing:-.03em;color:#f3f8fa;"
						>
							Order for the<br />machines you run.
						</h1>
						<p
							style="margin:30px 0 0;max-width:620px;font-size:clamp(17px,2vw,20.5px);line-height:1.6;color:#a4b7c3;font-weight:400;"
						>
							Ordo is a self-hosted system for teams running real workloads on their own bare metal and
							VMs. It brings <span style="color:#dbe7ec;">deliberate, auditable state management</span> without
							standing up enterprise tooling to get it.
						</p>
						<div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:40px;">
							<a
								href={docsUrl}
								style="display:inline-flex;align-items:center;gap:10px;font-size:16px;font-weight:600;color:#06222a;background:#35c2d1;padding:15px 26px;border-radius:11px;box-shadow:0 12px 40px -12px rgba(53,194,209,.55);"
							>
								Read the docs
								<svg
									width="17"
									height="17"
									viewBox="0 0 24 24"
									fill="none"
									stroke="#06222a"
									stroke-width="2.4"
									stroke-linecap="round"
									stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
							</a>
							<a
								href="#gap"
								style="display:inline-flex;align-items:center;gap:10px;font-size:16px;font-weight:600;color:#dbe7ec;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);padding:15px 24px;border-radius:11px;"
							>
								See where Ordo fits
								<svg
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="#dbe7ec"
									stroke-width="2.2"
									stroke-linecap="round"
									stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"></path></svg>
							</a>
						</div>
						<div
							style="display:flex;flex-wrap:wrap;gap:10px 26px;margin-top:40px;font-family:'IBM Plex Mono',monospace;font-size:13px;color:#647684;"
						>
							<span style="display:flex;align-items:center;gap:8px;"
								><span style="width:5px;height:5px;border-radius:50%;background:#35c2d1;"></span>Self-hosted by default</span
							>
							<span style="display:flex;align-items:center;gap:8px;"
								><span style="width:5px;height:5px;border-radius:50%;background:#35c2d1;"></span>Always encrypted</span
							>
							<span style="display:flex;align-items:center;gap:8px;"
								><span style="width:5px;height:5px;border-radius:50%;background:#35c2d1;"></span>Get started in minutes</span
							>
						</div>
					</div>
				</div>
			</section>

			<!-- ============ THE GAP ============ -->
			<section
				id="gap"
				style="position:relative;padding:clamp(90px,12vh,150px) clamp(20px,5vw,64px);background:#0a1219;border-top:1px solid rgba(255,255,255,.05);"
			>
				<div style="max-width:1180px;margin:0 auto;">
					<div data-reveal style="max-width:760px;margin-bottom:60px;">
						<div
							style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:.22em;color:#35c2d1;margin-bottom:20px;"
						>
							THE GAP
						</div>
						<h2
							style="margin:0;font-weight:700;font-size:clamp(30px,4.6vw,54px);line-height:1.05;letter-spacing:-.02em;color:#f0f6f8;"
						>
							Too big to operate,<br />or too small to trust.
						</h2>
						<p style="margin:24px 0 0;font-size:18px;line-height:1.6;color:#a4b7c3;max-width:640px;">
							Most infrastructure tooling makes you choose one or the other. Ordo is built for the space
							between them.
						</p>
					</div>
					<div style="display:grid;grid-template-columns:1fr auto 1fr;gap:clamp(18px,3vw,42px);align-items:stretch;">
						<div
							data-reveal
							style="padding:34px;border:1px solid rgba(224,162,78,.16);border-radius:18px;background:linear-gradient(180deg,rgba(224,162,78,.05),transparent);"
						>
							<div
								style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;color:#e0a24e;margin-bottom:16px;"
							>
								TOO BIG
							</div>
							<h3 style="margin:0 0 12px;font-size:22px;font-weight:600;color:#eef4f6;">Enterprise orchestration</h3>
							<p style="margin:0;font-size:15.5px;line-height:1.62;color:#93a8b5;">
								Solves hard problems, but assumes cloud-native workloads and a centralised control plane
								hosted somewhere else. That's significant investment just to run the tooling itself.
							</p>
						</div>
						<div
							data-reveal
							style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 clamp(4px,2vw,18px);"
						>
							<svg width="96" height="96" viewBox="0 0 64 64" fill="none">
								<path d="M12 29 A26 26 0 0 1 52 29" fill="none" stroke="#35c2d1" stroke-width="4.2" stroke-linecap="round"></path>
								<path d="M32 23 L20 35 M32 23 L32 35 M32 23 L44 35" stroke="#2a7f8c" stroke-width="2" stroke-linecap="round"></path>
								<circle cx="32" cy="19.5" r="4.4" fill="#57d6e3"></circle>
								<rect x="16" y="35" width="8" height="15" rx="2.4" fill="#385061" stroke="#5f7d93" stroke-width="1.4"></rect>
								<rect x="28" y="35" width="8" height="15" rx="2.4" fill="#1c3a44" stroke="#57d6e3" stroke-width="1.7"></rect>
								<rect x="40" y="35" width="8" height="15" rx="2.4" fill="#385061" stroke="#5f7d93" stroke-width="1.4"></rect>
							</svg>
							<div style="font-family:'Spectral',serif;font-style:italic;font-size:16px;color:#a9c5cf;margin-top:16px;text-align:center;">
								Ordo sits<br />in the gap
							</div>
						</div>
						<div
							data-reveal
							style="padding:34px;border:1px solid rgba(224,162,78,.16);border-radius:18px;background:linear-gradient(180deg,rgba(224,162,78,.05),transparent);"
						>
							<div
								style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.14em;color:#e0a24e;margin-bottom:16px;"
							>
								TOO SMALL
							</div>
							<h3 style="margin:0 0 12px;font-size:22px;font-weight:600;color:#eef4f6;">Scripts &amp; ad-hoc SSH</h3>
							<p style="margin:0;font-size:15.5px;line-height:1.62;color:#93a8b5;">
								Gets things done, but offers no guardrails, no audit trail, and no reliable way to know
								whether the fleet is actually in the state you think it is.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ============ HOW IT WORKS ============ -->
			<section
				id="architecture"
				style="position:relative;padding:clamp(90px,12vh,150px) clamp(20px,5vw,64px);background:linear-gradient(180deg,#0d1a24,#0a1219);border-top:1px solid rgba(255,255,255,.05);overflow:hidden;"
			>
				<div style="max-width:1180px;margin:0 auto;">
					<div data-reveal style="max-width:760px;margin-bottom:56px;">
						<div
							style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:.22em;color:#35c2d1;margin-bottom:20px;"
						>
							ARCHITECTURE
						</div>
						<h2
							style="margin:0;font-weight:700;font-size:clamp(30px,4.6vw,54px);line-height:1.05;letter-spacing:-.02em;color:#f0f6f8;"
						>
							One orchestrator, agents on every machine.
						</h2>
					</div>
					<div style="display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(30px,5vw,70px);align-items:center;">
						<div
							data-reveal
							style="position:relative;border:1px solid rgba(255,255,255,.08);border-radius:20px;background:#0b1a24;padding:30px;min-height:340px;"
						>
							<svg viewBox="0 0 460 340" style="width:100%;height:auto;overflow:visible;font-family:'IBM Plex Mono',monospace;">
								<defs>
									<marker id="ah" markerWidth="7" markerHeight="7" refX="4" refY="3.5" orient="auto"
										><path d="M0 0l6 3.5L0 7z" fill="#2b4c5e"></path></marker
									>
								</defs>
								<g
									stroke="#35c2d1"
									stroke-width="1.6"
									fill="none"
									stroke-dasharray="5 6"
									style="animation:ordoDash 1.4s linear infinite;"
								>
									<path d="M230 120 L110 250"></path>
									<path d="M230 120 L230 250"></path>
									<path d="M230 120 L350 250"></path>
								</g>
								<g>
									<circle cx="230" cy="90" r="62" fill="rgba(53,194,209,.06)"></circle>
									<rect x="164" y="60" width="132" height="60" rx="12" fill="#12303c" stroke="#35c2d1" stroke-width="1.6"></rect>
									<text x="230" y="85" text-anchor="middle" fill="#8ce7f1" font-size="13" font-weight="600">orchestrator</text>
									<text x="230" y="103" text-anchor="middle" fill="#7c98a8" font-size="10.5">state · audit log</text>
								</g>
								<g>
									<rect x="66" y="252" width="88" height="52" rx="10" fill="#12222f" stroke="#2b4c5e" stroke-width="1.4"></rect>
									<text x="110" y="274" text-anchor="middle" fill="#c7d6de" font-size="11" font-weight="600">agent</text>
									<text x="110" y="290" text-anchor="middle" fill="#3fca97" font-size="8.5">● in sync</text>
									<rect x="186" y="252" width="88" height="52" rx="10" fill="#12222f" stroke="#2b4c5e" stroke-width="1.4"></rect>
									<text x="230" y="274" text-anchor="middle" fill="#c7d6de" font-size="11" font-weight="600">agent</text>
									<text x="230" y="290" text-anchor="middle" fill="#e0a24e" font-size="8.5">● drift</text>
									<rect x="306" y="252" width="88" height="52" rx="10" fill="#12222f" stroke="#2b4c5e" stroke-width="1.4"></rect>
									<text x="350" y="274" text-anchor="middle" fill="#c7d6de" font-size="11" font-weight="600">agent</text>
									<text x="350" y="290" text-anchor="middle" fill="#3fca97" font-size="8.5">● in sync</text>
								</g>
								<rect x="116" y="175" width="228" height="19" rx="4" fill="#0b1a24"></rect>
								<text x="230" y="188" text-anchor="middle" fill="#7c98a8" font-size="10.5" letter-spacing="1.5">ENCRYPTED · AUTHENTICATED</text>
							</svg>
						</div>
						<div data-reveal style="display:flex;flex-direction:column;gap:26px;">
							<div style="display:flex;gap:16px;">
								<div
									style="flex:none;width:34px;height:34px;border-radius:9px;background:rgba(53,194,209,.1);border:1px solid rgba(53,194,209,.25);display:flex;align-items:center;justify-content:center;color:#57d6e3;font-family:'IBM Plex Mono',monospace;font-size:13px;"
								>
									1
								</div>
								<div>
									<h4 style="margin:0 0 6px;font-size:17px;font-weight:600;color:#eef4f6;">The orchestrator holds the intent</h4>
									<p style="margin:0;font-size:15px;line-height:1.6;color:#93a8b5;">
										Desired state and the full audit record live on one machine that never needs to be
										internet-accessible.
									</p>
								</div>
							</div>
							<div style="display:flex;gap:16px;">
								<div
									style="flex:none;width:34px;height:34px;border-radius:9px;background:rgba(53,194,209,.1);border:1px solid rgba(53,194,209,.25);display:flex;align-items:center;justify-content:center;color:#57d6e3;font-family:'IBM Plex Mono',monospace;font-size:13px;"
								>
									2
								</div>
								<div>
									<h4 style="margin:0 0 6px;font-size:17px;font-weight:600;color:#eef4f6;">Agents own their identity</h4>
									<p style="margin:0;font-size:15px;line-height:1.6;color:#93a8b5;">
										Each agent holds its own cryptographic key and must be explicitly approved before any work
										flows in either direction.
									</p>
								</div>
							</div>
							<div style="display:flex;gap:16px;">
								<div
									style="flex:none;width:34px;height:34px;border-radius:9px;background:rgba(53,194,209,.1);border:1px solid rgba(53,194,209,.25);display:flex;align-items:center;justify-content:center;color:#57d6e3;font-family:'IBM Plex Mono',monospace;font-size:13px;"
								>
									3
								</div>
								<div>
									<h4 style="margin:0 0 6px;font-size:17px;font-weight:600;color:#eef4f6;">Trust is pinned, not issued</h4>
									<p style="margin:0;font-size:15px;line-height:1.6;color:#93a8b5;">
										No certificates, no CAs, no expiry. Identities are pinned on first connection. If an
										agent's key changes it re-enters approval, and a changed orchestrator key is refused
										outright.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

